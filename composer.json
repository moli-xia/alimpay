{
    "name": "alimpay/bill-query-platform",
    "description": "AliMPay code payment platform",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "alipaysdk/openapi": "^3.0",
        "catfan/medoo": "^2.1",
        "ext-bcmath": "*",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "guzzlehttp/guzzle": "^7.3",
        "monolog/monolog": "^2.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "AliMPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AliMPay\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "bill-query": "php tests/bill_query_test.php",
        "payment-test": "php tests/payment_test.php"
    },
    "config": {
        "platform": {
            "php": "7.4.0"
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
